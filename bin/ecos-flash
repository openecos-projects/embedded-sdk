#!/usr/bin/env bash
set -euo pipefail

# ECOS `flash` subcommand
# Flashes the compiled firmware to the device

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_ROOT="$(dirname "$SCRIPT_DIR")"

# Color output
log() { echo -e "\033[1;32m[ECOS]\033[0m $*"; }
warn() { echo -e "\033[1;33m[WARN]\033[0m $*"; }
err() { echo -e "\033[1;31m[ERROR]\033[0m $*"; }

DEST_DIR="/run/media/$USER/YSYX-HFPLnk"

# Check if inside a project directory
check_project_dir() {
    if [[ ! -f "Makefile" ]] && [[ ! -f ".ecos-project" ]]; then
        err "Not an ECOS project directory."
        err "Run this command in a directory containing a Makefile or .ecos-project file."
        exit 1
    fi
}

flash_firmware() {
    check_project_dir

    # Check if the destination exists
    if [[ ! -d "$DEST_DIR" ]]; then
        err "Device not found at $DEST_DIR"
        err "Please make sure the device is connected and mounted."
        exit 1
    fi

    log "Flashing firmware to $DEST_DIR..."

    local flashed=false

    # Support for both asm and c project binary locations
    if [[ -f "build/retrosoc_fw.bin" ]]; then
        cp build/retrosoc_fw.bin "$DEST_DIR/" 2>/dev/null || true
        flashed=true
    fi

    sleep 0.5

    if [[ -f "build/retrosoc_fw.bin" ]]; then
        cp build/retrosoc_fw.bin "$DEST_DIR/" 2>/dev/null || true
        flashed=true
    fi

    if [[ "$flashed" == "false" ]]; then
        err "Firmware binary not found."
        err "Please compile the project first using 'make'."
        exit 1
    fi

    log "Flash completed successfully!"
}

flash_firmware
